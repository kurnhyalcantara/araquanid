# Local dev env vars — copy to .env (gitignored) and fill in real values.
# This is the naming convention for all ARAQUANID_ env vars: ARAQUANID_ prefix,
# "__" separates nesting levels (ARAQUANID_POSTGRES__HOST -> postgres.host).
# Anything left unset here falls back to the defaults in config/config.go.

# --- postgres (no password default — must be set explicitly) ---
ARAQUANID_POSTGRES__HOST=localhost
ARAQUANID_POSTGRES__PORT=5432
ARAQUANID_POSTGRES__USER=araquanid
ARAQUANID_POSTGRES__PASSWORD=araquanid
ARAQUANID_POSTGRES__DATABASE=araquanid
ARAQUANID_POSTGRES__SSL_MODE=disable

# --- redis ---
ARAQUANID_REDIS__ADDR=localhost:6379
# ARAQUANID_REDIS__CACHE_TTL=5m

# --- log ---
ARAQUANID_LOG__LEVEL=debug
ARAQUANID_LOG__FORMAT=text

# --- identity context (outbound gRPC client; unset leaves the ACL unavailable) ---
# ARAQUANID_IDENTITY__ADDR=localhost:50052

# --- migrations (make migrate-up/migrate-down read these too) ---
# Set this instead if your password has reserved URL characters (e.g. '@' -> '%40').
# ARAQUANID_MIGRATE_DATABASE_URL=postgres://user:pass@localhost:5432/araquanid?sslmode=disable
